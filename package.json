{
  "name": "pi-errands",
  "version": "0.3.0",
  "packageManager": "npm@11.12.1",
  "description": "Task-tracking extension for pi — plans, errands, and chores to keep agents on track.",
  "license": "MIT",
  "author": "Jonas Damtoft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jomik/pi-errands.git"
  },
  "homepage": "https://github.com/Jomik/pi-errands",
  "keywords": [
    "pi",
    "agent",
    "task-tracking",
    "errands",
    "llm"
  ],
  "type": "module",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "typebox": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "typebox": "^1.1.38",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
